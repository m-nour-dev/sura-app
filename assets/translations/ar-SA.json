  "zikr_subhan_allah": "سُبْحَانَ اللَّهِ",
  "zikr_alhamdulillah": "الْحَمْدُ لِلَّهِ",
  "zikr_allahu_akbar": "اللَّهُ أَكْبَرُ",
  "zikr_la_ilaha_illa_allah": "لَا إِلَهَ إِلَّا اللَّهُ",
  "zikr_astaghfirullah": "أَسْتَغْفِرُ اللَّهَ الْعَظِيمَ الَّذِي لَا إِلَهَ إِلَّا هُوَ الْحَيَّ الْقَيُّومَ وَأَتُوبُ إِلَيْهِ",
  "zikr_la_hawla_wala_quwwata_illa_billah": "لَا حَوْلَ وَلَا قُوَّةَ إِلَّا بِاللَّهِ الْعَلِيِّ الْعَظِيمِ",
  "zikr_hasbunallah_wanikmal_wakil": "حَسْبُنَا اللَّهُ وَنِعْمَ الْوَكِيلُ، نِعْمَ الْمَوْلَى وَنِعْمَ النَّصِيرُ",
  "zikr_allahumma_salli_ala_muhammad": "اللَّهُمَّ صَلِّ وَسَلِّمْ عَلَى نَبِيِّنَا مُحَمَّدٍ",
  "zikr_subhanallahi_wabihamdihi": "سُبْحَانَ اللَّهِ وَبِحَمْدِهِ",
  "zikr_subhanallahi_al_azim": "سُبْحَانَ اللَّهِ الْعَظِيمِ",
  "zikr_la_ilaha_illallah_wahdahu": "لَا إِلَهَ إِلَّا اللَّهُ وَحْدَهُ لَا شَرِيكَ لَهُ، لَهُ الْمُلْكُ وَلَهُ الْحَمْدُ، وَهُوَ عَلَى كُلِّ شَيْءٍ قَدِيرٌ",
  "zikr_subhanallahi_wa_bi_hamdih_adada_khalqih": "سُبْحَانَ اللَّهِ وَبِحَمْدِهِ: عَدَدَ خَلْقِهِ، وَرِضَا نَفْسِهِ، وَزِنَةَ عَرْشِهِ، وَمِدَادَ كَلِمَاتِهِ",
  "zikr_ya_hayyu_ya_qayyum": "يَا حَيُّ يَا قَيُّومُ بِرَحْمَتِكَ أَسْتَغِيثُ، أَصْلِحْ لِي شَأْنِي كُلَّهُ وَلَا تَكِلْنِي إِلَى نَفْسِي طَرْفَةَ عَيْنٍ",
  "zikr_allahumma_ajirni_minan_nar": "اللَّهُمَّ أَجِرْنِي مِنَ النَّارِ",
  "zikr_la_ilaha_illa_anta_subhanaka": "لَا إِلَهَ إِلَّا أَنْتَ سُبْحَانَكَ إِنِّي كُنْتُ مِنَ الظَّالِمِينَ",
  "zikr_ya_muqallibal_qulub": "يَا مُقَلِّبَ الْقُلُوبِ ثَبِّتْ قَلْبِي عَلَى دِينِكَ",
  "zikr_allahumma_innaka_afuwwun": "اللَّهُمَّ إِنَّكَ عَفُوٌّ تُحِبُّ الْعَفْوَ فَاعْفُ عَنِّي",
  "zikr_raditu_billahi_rabba": "رَضِيتُ بِاللَّهِ رَبَّا، وَبِالْإِسْلَامِ دِينًا، وَبِمُحَمَّدٍ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ نَبِيًّا",
  "zikr_allahumma_aini_ala_zhikrika": "اللَّهُمَّ أَعِنِّي عَلَى ذِكْرِكَ وَشُكْرِكَ وَحُسْنِ عِبَادَتِكَ",
  "zikr_hasbi_allah_walahu_al_arsh": "حَسْبِيَ اللَّهُ لَا إِلَهَ إِلَّا هُوَ عَلَيْهِ تَوَكَّلْتُ وَهُوَ رَبُّ الْعَرْشِ الْعَظِيمِ",
  "zikr_subhan_allah_walhamdu_lillah": "سُبْحَانَ اللَّهِ، وَالْحَمْدُ لِلَّهِ، وَلَا إِلَهَ إِلَّا اللَّهُ، وَاللَّهُ أَكْبَرُ",
  "zikr_ya_dhal_jalali_wal_ikram": "يَا ذَا الْجَلَالِ وَالْإِكْرَامِ",
  "zikr_la_ilaha_illallah_al_malik": "لَا إِلَهَ إِلَّا اللَّهُ الْمَلِكُ الْحَقُّ الْمُبِينُ",
  "zikr_astaghfirullah_lil_muminin": "أَسْتَغْفِرُ اللَّهَ لِلْمُؤْمِنِينَ وَالْمُؤْمِنَاتِ",
  "zikr_allahumma_maghfiratuka_awsa": "اللَّهُمَّ مَغْفِرَتُكَ أَوْسَعُ مِنْ ذُنُوبِي، وَرَحْمَتُكَ أَرْجَى عِنْدِي مِنْ عَمَلِي",
  "zikr_allahumma_salli_ala_muhammad_full": "اللَّهُمَّ صَلِّ عَلَى مُحَمَّدٍ وَعَلَى آلِ مُحَمَّدٍ كَمَا صَلَّيْتَ عَلَى إِبْرَاهِيمَ وَعَلَى آلِ إِبْرَاهِيمَ إِنَّكَ حَمِيدٌ مَجِيدٌ",
  "zikr_allahumma_inni_asalukal_jannah": "اللَّهُمَّ إِنِّي أَسْأَلُكَ الْجَنَّةَ، وَأَعُوذُ بِكَ مِنَ النَّارِ",
  "zikr_la_ilaha_illallah_al_azim_al_halim": "لَا إِلَهَ إِلَّا اللَّهُ الْعَظِيمُ الْحَلِيمُ، لَا إِلَهَ إِلَّا اللَّهُ رَبُّ الْعَرْشِ الْعَظِيمِ",
