   "sunnah_explanation_title": "شرح السنة",
   "sunnah_explanation_button": "شرح",
   "close_button": "إغلاق",
   "sunnah_1_text": "المضمضة والاستنشاق من غرفة واحدة",
   "sunnah_1_source": "متفق عليه",
   "sunnah_1_explanation": "أن يأخذ غرفة واحدة من الماء، فيتمضمض ببعضها، ويستنشق بالباقي، ويفعل ذلك ثلاث مرات.",
   "sunnah_2_text": "الدعاء بعد الوضوء",
   "sunnah_2_source": "رواه الترمذي",
   "sunnah_2_explanation": "يقول بعد الفراغ من الوضوء: 'أشهد أن لا إله إلا الله وحده لا شريك له، وأشهد أن محمدًا عبده ورسوله..'.",
   "sunnah_3_text": "صلاة ركعتين بعد الوضوء",
   "sunnah_3_source": "متفق عليه",
   "sunnah_3_explanation": "يستحب لمن توضأ أن يصلي ركعتين لا يحدث فيهما نفسه بشيء من أمور الدنيا، وهي سبب لمغفرة الذنوب.",
   "sunnah_4_text": "التنويع في دعاء الاستفتاح",
   "sunnah_4_source": "رواه البخاري ومسلم",
   "sunnah_4_explanation": "يستحب أن ينوع المصلي في دعاء الاستفتاح، فتارة يقول: 'اللهم باعد بيني وبين خطاياي..' وتارة: 'سبحانك اللهم وبحمدك..'.",
   "sunnah_5_text": "السواك عند كل صلاة",
   "sunnah_5_source": "متفق عليه",
   "sunnah_5_explanation": "يستحب استخدام السواك عند القيام للصلاة، وهو مطهرة للفم ومرضاة للرب.",
   "sunnah_6_text": "الصلاة إلى سترة",
   "sunnah_6_source": "متفق عليه",
   "sunnah_6_explanation": "أن يضع المصلي شيئًا أمامه (جدار، عمود، أو شيء مرتفع) ليمنع المارة من المرور بين يديه، وهذا سنة مؤكدة.",
   "sunnah_7_text": "جلسة الاستراحة",
   "sunnah_7_source": "رواه البخاري",
   "sunnah_7_explanation": "هي جلسة خفيفة جداً يسيرة يجلسها المصلي بعد السجدة الثانية من الركعة الأولى والركعة الثالثة قبل أن يقوم.",
   "sunnah_8_text": "الإقعاء بين السجدتين",
   "sunnah_8_source": "رواه مسلم",
   "sunnah_8_explanation": "هو أن ينصب قدميه ويجلس على عقبيه بين السجدتين، وهي سنة تفعل أحياناً.",
   "sunnah_9_text": "سجود الشكر",
   "sunnah_9_source": "رواه أبو داود والترمذي",
   "sunnah_9_explanation": "يسجد المسلم سجدة واحدة يحمد الله فيها ويشكره عند حصول نعمة جديدة أو اندفاع نقمة.",
   "sunnah_10_text": "نفض الفراش قبل النوم",
   "sunnah_10_source": "متفق عليه",
   "sunnah_10_explanation": "ينفض فراشه بداخل إزاره ثلاث مرات، لأنه لا يدري ما خلفه عليه في فراشه.",
   "sunnah_11_text": "النوم على طهارة",
   "sunnah_11_source": "متفق عليه",
   "sunnah_11_explanation": "يستحب للمسلم أن يتوضأ وضوءه للصلاة قبل أن ينام.",
   "sunnah_12_text": "قراءة سورة الملك قبل النوم",
   "sunnah_12_source": "رواه أبو داود والترمذي",
   "sunnah_12_explanation": "هي المانعة من عذاب القبر، ويستحب قراءتها كل ليلة.",
   "sunnah_13_text": "لعق الأصابع بعد الطعام",
   "sunnah_13_source": "رواه مسلم",
   "sunnah_13_explanation": "السنة لعق الأصابع قبل مسحها أو غسلها، فإن فيها بركة لا يدري في أي طعامه هي.",
   "sunnah_14_text": "حمد الله بعد الأكل والشرب",
   "sunnah_14_source": "رواه مسلم",
   "sunnah_14_explanation": "يقول: الحمد لله الذي أطعمنا وسقانا وجعلنا مسلمين، أو غيرها من صيغ الحمد.",
   "sunnah_15_text": "التنفس خارج الإناء عند الشرب",
   "sunnah_15_source": "متفق عليه",
   "sunnah_15_explanation": "يشرب الماء على ثلاث دفعات، ويتنفس خارج الإناء بين كل رشفة وأخرى.",
   "sunnah_16_text": "مبادرة من لقيت بالسلام",
   "sunnah_16_source": "رواه أبو داود",
   "sunnah_16_explanation": "أن يكون هو البادئ بالسلام عند اللقاء، وخيرهما الذي يبدأ بالسلام.",
   "sunnah_17_text": "إفشاء السلام",
   "sunnah_17_source": "متفق عليه",
   "sunnah_17_explanation": "نشر السلام وإلقاؤه على من عرفت ومن لم تعرف من المسلمين.",
   "sunnah_18_text": "التبسم في وجه أخيك",
   "sunnah_18_source": "رواه الترمذي",
   "sunnah_18_explanation": "إظهار البشر والابتسامة عند لقاء المسلم، فهو عمل صالح يؤجر عليه.",
   "sunnah_19_text": "المصافحة عند اللقاء",
   "sunnah_19_source": "رواه أبو داود والترمذي",
   "sunnah_19_explanation": "تصافح المسلمين يوجب تساقط الذنوب كما تتساقط أوراق الشجر.",
   "sunnah_20_text": "زيارة المقابر",
   "sunnah_20_source": "رواه مسلم",
   "sunnah_20_explanation": "تسن زيارة المقابر للرجال لتذكر الآخرة والدعاء للموتى.",
   "sunnah_21_text": "صلاة الضحى",
   "sunnah_21_source": "رواه مسلم",
   "sunnah_21_explanation": "أقلها ركعتان، ووقتها من ارتفاع الشمس قيد رمح إلى قبيل الزوال، وهي صلاة الأوابين.",
   "sunnah_22_text": "صلاة الوتر",
   "sunnah_22_source": "متفق عليه",
   "sunnah_22_explanation": "أن يختم صلاته بالليل بركعة واحدة، وهي سنة مؤكدة.",
   "sunnah_23_text": "المشي حافياً أحياناً",
   "sunnah_23_source": "رواه أحمد وأبو داود",
   "sunnah_23_explanation": "يستحب المشي بدون نعلين أحياناً تواضعاً لله وتدريباً للنفس، في أماكن مناسبة.",
   "sunnah_24_text": "كتابة الوصية",
   "sunnah_24_source": "متفق عليه",
   "sunnah_24_explanation": "من كان له شيء يريد أن يوصي فيه، فلا يبيت ليلتين إلا ووصيته  عند رأسه.",
   "sunnah_25_text": "الدعاء عند نزول المطر",
   "sunnah_25_source": "رواه البخاري",
   "sunnah_25_explanation": "يستحب كشف جزء من البدن ليصيبه المطر والقول: اللهم صيباً نافعاً.",
   "sunnah_26_text": "كف الصبيان عند الغروب",
   "sunnah_26_source": "متفق عليه",
   "sunnah_26_explanation": "منع الأطفال من الخروج وقت غروب الشمس (بداية انتشار الشياطين) ثم تركهم بعد ذهاب ساعة من الليل.",
