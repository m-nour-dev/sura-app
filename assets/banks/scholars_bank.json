[
  {
    "id": "scholars_001",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "القلب في سيره إلى الله بمنزلة الطائر؛ المحبة رأسه والخوف والرجاء جناحاه.",
    "source": "ابن القيم - مدارج السالكين",
    "grade": "حكمة",
    "short_explanation": "توازن القلب بين الرجاء والخوف أصل الثبات.",
    "trigger_tags": [
      "تذكير_عام",
      "إلهام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_002",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "من علامة تعظيم الأمر والنهي ألا يعارض بترخص جاف.",
    "source": "ابن رجب - جامع العلوم والحكم",
    "grade": "حكمة",
    "short_explanation": "التعظيم الحقيقي يظهر في العمل لا في الكلام.",
    "trigger_tags": [
      "تذكير_عام",
      "تيقظ"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_003",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "العلم يهتف بالعمل فإن أجابه وإلا ارتحل.",
    "source": "الإمام الغزالي - إحياء علوم الدين",
    "grade": "حكمة",
    "short_explanation": "العلم بلا تطبيق يفقد أثره سريعاً.",
    "trigger_tags": [
      "تذكير_عام",
      "إلهام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_004",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "الإخلاص أن يكون سكونك وحركتك لله وحده.",
    "source": "ابن القيم - الفوائد",
    "grade": "حكمة",
    "short_explanation": "الإخلاص يطهر القصد في كل عبادة.",
    "trigger_tags": [
      "إلهام",
      "تذكير_عام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_005",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "من أصلح سريرته أصلح الله علانيته.",
    "source": "ابن رجب - لطائف المعارف",
    "grade": "حكمة",
    "short_explanation": "الباطن الصالح يثمر ظاهرًا مستقيمًا.",
    "trigger_tags": [
      "تيقظ",
      "تذكير_عام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_006",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "السعيد من وعظ بغيره، والشقي من اتعظ به غيره.",
    "source": "ابن الجوزي - صيد الخاطر",
    "grade": "حكمة",
    "short_explanation": "خذ العبرة قبل أن تصبح أنت العبرة.",
    "trigger_tags": [
      "تيقظ",
      "إلهام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_007",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "دواء القلب خمسة: قراءة القرآن بتدبر، وخلاء البطن، وقيام الليل، والتضرع عند السحر، ومجالسة الصالحين.",
    "source": "ابن القيم - زاد المعاد",
    "grade": "حكمة",
    "short_explanation": "برنامج عملي لإحياء القلب يومياً.",
    "trigger_tags": [
      "تحفيز",
      "تذكير_عام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_008",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "النفس إن لم تشغلها بالحق شغلتك بالباطل.",
    "source": "ابن القيم - الفوائد",
    "grade": "حكمة",
    "short_explanation": "املأ يومك بطاعة قبل أن يملأه الفراغ.",
    "trigger_tags": [
      "تحفيز",
      "تيقظ"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_009",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "الموفق من فتح له باب الدعاء وألهمه الافتقار.",
    "source": "ابن تيمية - مجموع الفتاوى",
    "grade": "حكمة",
    "short_explanation": "الدعاء توفيق عظيم لا يُحرم منه إلا غافل.",
    "trigger_tags": [
      "إلهام",
      "تذكير_عام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_010",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "إذا أردت أن تعرف ما لك عند الله فانظر ما لله عندك.",
    "source": "ابن القيم - الوابل الصيب",
    "grade": "حكمة",
    "short_explanation": "مكانة الطاعة في قلبك مرآة لحالك.",
    "trigger_tags": [
      "تيقظ",
      "تذكير_عام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_011",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "قيمة كل امرئ ما يحسنه.",
    "source": "الغزالي - إحياء علوم الدين",
    "grade": "حكمة",
    "short_explanation": "أحسن عبادتك يعلُ قدرك عند الله.",
    "trigger_tags": [
      "تحفيز",
      "إلهام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_012",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "العبادة لا تقوم إلا على العلم، والعلم لا ينفع إلا مع العمل.",
    "source": "ابن عثيمين - شرح الأصول الثلاثة",
    "grade": "حكمة",
    "short_explanation": "توازن العلم والعمل هو طريق الثبات.",
    "trigger_tags": [
      "تحفيز",
      "تذكير_عام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_013",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "من صدق الله صدقه الله.",
    "source": "ابن باز - مجموع الفتاوى",
    "grade": "حكمة",
    "short_explanation": "الصدق مع الله يجلب المعونة والتيسير.",
    "trigger_tags": [
      "تحفيز",
      "إلهام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_014",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "لا يزال العبد بخير ما دام له واعظ من قلبه.",
    "source": "ابن الجوزي - صيد الخاطر",
    "grade": "حكمة",
    "short_explanation": "محاسبة النفس اليومية تحمي من الغفلة.",
    "trigger_tags": [
      "تيقظ",
      "تذكير_عام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_015",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "الذنوب جراحات، ورب جرح وقع في مقتل.",
    "source": "ابن القيم - الجواب الكافي",
    "grade": "حكمة",
    "short_explanation": "الصغيرة مع الإصرار تفسد القلب.",
    "trigger_tags": [
      "تيقظ",
      "إلهام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_016",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "دوام القليل خير من كثير منقطع.",
    "source": "ابن رجب - فتح الباري",
    "grade": "حكمة",
    "short_explanation": "الاستمرارية اليومية أعظم من الاندفاع المؤقت.",
    "trigger_tags": [
      "تحفيز",
      "تذكير_عام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_017",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "الغفلة داء القلب، وذكر الله دواؤه.",
    "source": "ابن القيم - الوابل الصيب",
    "grade": "حكمة",
    "short_explanation": "الذكر اليومي يحفظ القلب حيًّا.",
    "trigger_tags": [
      "تذكير_عام",
      "تحفيز"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_018",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "من عرف قدر الوقت لم يضيعه.",
    "source": "ابن الجوزي - تلبيس إبليس",
    "grade": "حكمة",
    "short_explanation": "إدارة الوقت عبادة تعين على الإنجاز.",
    "trigger_tags": [
      "تحفيز",
      "تيقظ"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_019",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "حسن الظن بالله مع حسن العمل هو طريق النجاة.",
    "source": "ابن عثيمين - شرح رياض الصالحين",
    "grade": "حكمة",
    "short_explanation": "رجاء بلا عمل أمانٍ، والعمل بلا رجاء قسوة.",
    "trigger_tags": [
      "إلهام",
      "تذكير_عام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_020",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "أعظم الناس راحة من كانت همومه همًا واحدًا: رضى الله.",
    "source": "ابن القيم - طريق الهجرتين",
    "grade": "حكمة",
    "short_explanation": "توحيد الهدف يخفف تشتت القلب.",
    "trigger_tags": [
      "إلهام",
      "تحفيز"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_021",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "الصبر حبس النفس على ما يرضي الله.",
    "source": "ابن تيمية - مجموع الفتاوى",
    "grade": "حكمة",
    "short_explanation": "الصبر العملي وقود الطريق إلى الله.",
    "trigger_tags": [
      "تحفيز",
      "تذكير_عام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_022",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "من لم يجد لذة الطاعة فليتهم قلبه.",
    "source": "ابن القيم - الفوائد",
    "grade": "حكمة",
    "short_explanation": "فتش عن سبب القسوة وعالجه بالتوبة.",
    "trigger_tags": [
      "تيقظ",
      "إلهام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_023",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "البركة في أول الوقت لمن صدق مع الله.",
    "source": "ابن باز - مجموع الفتاوى",
    "grade": "حكمة",
    "short_explanation": "بداية اليوم بطاعة تصنع فرقاً كبيراً.",
    "trigger_tags": [
      "تحفيز",
      "تذكير_عام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_024",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "إذا ضاق صدرك فافزع إلى الصلاة.",
    "source": "ابن عثيمين - لقاءات الباب المفتوح",
    "grade": "حكمة",
    "short_explanation": "الصلاة ملجأ القلب عند الشدائد.",
    "trigger_tags": [
      "تكاسل_عن_salah",
      "تذكير_عام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_025",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "القرآن حياة القلوب كما أن المطر حياة الأرض.",
    "source": "ابن القيم - مفتاح دار السعادة",
    "grade": "حكمة",
    "short_explanation": "الورد القرآني اليومي غذاء القلب.",
    "trigger_tags": [
      "تكاسل_عن_wird",
      "تحفيز"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_026",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "من لازم الاستغفار جعل الله له من كل هم فرجًا.",
    "source": "ابن باز - نور على الدرب",
    "grade": "حكمة",
    "short_explanation": "الاستغفار مفتاح تفريج الكروب.",
    "trigger_tags": [
      "تكاسل_عن_tasbih",
      "تذكير_عام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_027",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "الدعاء سلاح المؤمن، فمن تركه ضعف قلبه.",
    "source": "ابن تيمية - مجموع الفتاوى",
    "grade": "حكمة",
    "short_explanation": "الدعاء يقوي اليقين ويربط القلب بالله.",
    "trigger_tags": [
      "إلهام",
      "تحفيز"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_028",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "المؤمن بين نعمة تحتاج شكرًا وذنب يحتاج استغفارًا.",
    "source": "ابن القيم - مدارج السالكين",
    "grade": "حكمة",
    "short_explanation": "حياتك لا تخرج عن شكر أو توبة.",
    "trigger_tags": [
      "تيقظ",
      "تذكير_عام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_029",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "الخير عادة، فدرّب نفسك عليه حتى تألفه.",
    "source": "الغزالي - إحياء علوم الدين",
    "grade": "حكمة",
    "short_explanation": "العادات الصالحة تُبنى بالتدرج والثبات.",
    "trigger_tags": [
      "تحفيز",
      "إلهام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_030",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "إذا أردت الثبات فأكثر من دعاء: يا مقلب القلوب ثبت قلبي على دينك.",
    "source": "ابن عثيمين - شرح الأذكار",
    "grade": "حكمة",
    "short_explanation": "أعظم أسباب الثبات كثرة الالتجاء لله.",
    "trigger_tags": [
      "تحفيز",
      "تذكير_عام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_031",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "من صدق في الطلب وصل، ومن داوم على الباب فُتح له.",
    "source": "ابن القيم - الفوائد",
    "grade": "حكمة",
    "short_explanation": "الاستمرار الصادق يفتح أبواب الخير.",
    "trigger_tags": [
      "تحفيز",
      "إلهام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_032",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "القلب إذا امتلأ بالقرآن ضاقت عليه المعصية.",
    "source": "ابن رجب - لطائف المعارف",
    "grade": "حكمة",
    "short_explanation": "حضور القرآن يحصن القلب من الزلل.",
    "trigger_tags": [
      "تكاسل_عن_wird",
      "تيقظ"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_033",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "من أكثر من ذكر الموت هان عليه ترك الشهوات.",
    "source": "ابن الجوزي - التذكرة",
    "grade": "حكمة",
    "short_explanation": "استحضار الآخرة يعين على ضبط النفس.",
    "trigger_tags": [
      "تيقظ",
      "تذكير_عام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_034",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "العبد محتاج إلى هداية كل يوم كما يحتاج إلى الطعام والشراب.",
    "source": "ابن تيمية - الفتاوى",
    "grade": "حكمة",
    "short_explanation": "الهداية طلب يومي لا يتوقف.",
    "trigger_tags": [
      "تذكير_عام",
      "إلهام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_035",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "صلاح القلب مقدم على صلاح الجوارح، والجوارح تبع له.",
    "source": "ابن القيم - إغاثة اللهفان",
    "grade": "حكمة",
    "short_explanation": "ابدأ بإصلاح الداخل يصلح الخارج تلقائياً.",
    "trigger_tags": [
      "تيقظ",
      "تذكير_عام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_036",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "من علامات القبول أن ترى نفسك مقصراً بعد كل طاعة.",
    "source": "ابن رجب - جامع العلوم والحكم",
    "grade": "حكمة",
    "short_explanation": "التواضع بعد العمل علامة إخلاص.",
    "trigger_tags": [
      "تيقظ",
      "إلهام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_037",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "أعظم الخسارة أن يمر يومك بلا ذكر ولا قرآن.",
    "source": "ابن باز - مجموع الفتاوى",
    "grade": "حكمة",
    "short_explanation": "اجعل لك وردًا لا يسقط مهما ازدحم يومك.",
    "trigger_tags": [
      "تكاسل_عن_wird",
      "تكاسل_عن_tasbih"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_038",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "قيام الليل مدرسة الإخلاص والصبر.",
    "source": "ابن عثيمين - لقاء الباب المفتوح",
    "grade": "حكمة",
    "short_explanation": "الليل يصنع علاقة خاصة بين العبد وربه.",
    "trigger_tags": [
      "تحفيز",
      "إلهام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_039",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "من عرف الله استحيا أن يراه حيث نهاه.",
    "source": "ابن القيم - مدارج السالكين",
    "grade": "حكمة",
    "short_explanation": "المعرفة بالله تثمر مراقبة صادقة.",
    "trigger_tags": [
      "تيقظ",
      "تذكير_عام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_040",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "أحسن إلى الناس ما استطعت، فإن القلوب مجبولة على حب من أحسن إليها.",
    "source": "الغزالي - إحياء علوم الدين",
    "grade": "حكمة",
    "short_explanation": "حسن الخلق باب عظيم للدعوة والتأثير.",
    "trigger_tags": [
      "إلهام",
      "تذكير_عام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_041",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "من أراد الله به خيرًا فتح له باب الذكر.",
    "source": "ابن القيم - الوابل الصيب",
    "grade": "حكمة",
    "short_explanation": "الذكر علامة لطف من الله بالعبد.",
    "trigger_tags": [
      "تكاسل_عن_tasbih",
      "تحفيز"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_042",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "كلما ازددت علمًا ازددت خوفًا من الله.",
    "source": "ابن باز - الفتاوى",
    "grade": "حكمة",
    "short_explanation": "العلم الصحيح يقود للتقوى لا للكبر.",
    "trigger_tags": [
      "تيقظ",
      "إلهام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_043",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "المحروم من حرم الدعاء، والمخذول من أعرض عنه.",
    "source": "ابن تيمية - مجموع الفتاوى",
    "grade": "حكمة",
    "short_explanation": "لا تترك باب الدعاء في كل حال.",
    "trigger_tags": [
      "تحفيز",
      "تذكير_عام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_044",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "النظر في عيوب النفس أولى من تتبع عيوب الناس.",
    "source": "ابن الجوزي - صيد الخاطر",
    "grade": "حكمة",
    "short_explanation": "إصلاح الذات مقدم على نقد الآخرين.",
    "trigger_tags": [
      "تيقظ",
      "تذكير_عام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_045",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "من أدام الطرق على الباب فُتح له.",
    "source": "ابن القيم - الفوائد",
    "grade": "حكمة",
    "short_explanation": "الاستمرار في الطاعة يفتح لك أبوابًا جديدة.",
    "trigger_tags": [
      "تحفيز",
      "إلهام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_046",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "الاستقامة خير من ألف كرامة.",
    "source": "ابن تيمية - الفتاوى",
    "grade": "حكمة",
    "short_explanation": "الثبات على الطاعة أعظم من طلب الخوارق.",
    "trigger_tags": [
      "تذكير_عام",
      "تحفيز"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_047",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "إذا جاءك الفتور فتمسك بالفرائض ولا تترك الأوراد.",
    "source": "ابن عثيمين - شرح رياض الصالحين",
    "grade": "حكمة",
    "short_explanation": "وقت الفتور يحتاج ثباتًا لا انسحابًا.",
    "trigger_tags": [
      "تحفيز",
      "تكاسل_عن_wird"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_048",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "من أصلح ما بينه وبين الله أصلح الله ما بينه وبين الناس.",
    "source": "ابن القيم - الفوائد",
    "grade": "حكمة",
    "short_explanation": "إصلاح العلاقة مع الله ينعكس على كل حياتك.",
    "trigger_tags": [
      "إلهام",
      "تذكير_عام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_049",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "أفضل الجهاد جهاد النفس على الطاعة.",
    "source": "ابن باز - مجموع الفتاوى",
    "grade": "حكمة",
    "short_explanation": "مجاهدة النفس اليومية أصل النجاح.",
    "trigger_tags": [
      "تحفيز",
      "تيقظ"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_050",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "التوبة الصادقة تمحو ما قبلها وتفتح بداية جديدة.",
    "source": "ابن رجب - جامع العلوم والحكم",
    "grade": "حكمة",
    "short_explanation": "لا تؤخر الرجوع إلى الله مهما كان تقصيرك.",
    "trigger_tags": [
      "تيقظ",
      "إلهام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_051",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "من لازم القرآن بصدق رأى أثره في قوله وخلقه.",
    "source": "ابن القيم - التبيان",
    "grade": "حكمة",
    "short_explanation": "القرآن يصنع الشخصية قبل المعلومات.",
    "trigger_tags": [
      "تكاسل_عن_wird",
      "تحفيز"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_052",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "العاقل من كان يومه خيرًا من أمسه.",
    "source": "ابن الجوزي - صيد الخاطر",
    "grade": "حكمة",
    "short_explanation": "التقدم اليومي ولو قليلًا هو النجاح الحقيقي.",
    "trigger_tags": [
      "تحفيز",
      "تذكير_عام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_053",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "أكثر ما يثبت العبد: صحبة صالحة وذكر دائم.",
    "source": "ابن عثيمين - لقاءات الباب المفتوح",
    "grade": "حكمة",
    "short_explanation": "البيئة الصالحة تعينك على الاستمرار.",
    "trigger_tags": [
      "تحفيز",
      "إلهام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_054",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "إذا وجدت قسوة في قلبك فأكثر من تلاوة القرآن.",
    "source": "ابن باز - الفتاوى",
    "grade": "حكمة",
    "short_explanation": "القرآن أنفع علاج لقسوة القلب.",
    "trigger_tags": [
      "تكاسل_عن_wird",
      "تيقظ"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_055",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "أحب الأعمال إلى الله أدومها وإن قل.",
    "source": "ابن رجب - شرح الحديث",
    "grade": "حكمة",
    "short_explanation": "المداومة أهم من الكثرة المؤقتة.",
    "trigger_tags": [
      "تحفيز",
      "تذكير_عام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_056",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "اللسان إن لم تذكر به الله شغلك بما يضرك.",
    "source": "ابن القيم - الوابل الصيب",
    "grade": "حكمة",
    "short_explanation": "اشغل لسانك بالذكر قبل أن يشغلك باللغو.",
    "trigger_tags": [
      "تكاسل_عن_tasbih",
      "تذكير_عام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_057",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "العبد يقطع إلى الله بالصدق ما لا يقطعه بكثرة العمل.",
    "source": "ابن تيمية - الفتاوى",
    "grade": "حكمة",
    "short_explanation": "الصدق يبارك العمل القليل فيعظمه.",
    "trigger_tags": [
      "إلهام",
      "تحفيز"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_058",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "من داوم على الاستقامة رأى لطف الله في التفاصيل الصغيرة قبل الكبيرة.",
    "source": "ابن عثيمين - شرح العقيدة",
    "grade": "حكمة",
    "short_explanation": "الثبات يجلب السكينة والبركة يومًا بعد يوم.",
    "trigger_tags": [
      "تحفيز",
      "تذكير_عام"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_059",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "أطول الناس ندمًا من ضيّع أوقات قدرته على الطاعة.",
    "source": "ابن الجوزي - صيد الخاطر",
    "grade": "حكمة",
    "short_explanation": "اغتنم قوتك وصحتك قبل الفوات.",
    "trigger_tags": [
      "تيقظ",
      "تحفيز"
    ],
    "season_tags": [
      "عام"
    ]
  },
  {
    "id": "scholars_060",
    "category": "scholars",
    "type": "hikma",
    "arabic_text": "إذا فتح لك باب الطاعة فلا تنظر لصغره، ولكن انظر لمن وفقك له.",
    "source": "ابن القيم - الفوائد",
    "grade": "حكمة",
    "short_explanation": "كل طاعة منحة تستحق الشكر والاستمرار.",
    "trigger_tags": [
      "إلهام",
      "تذكير_عام"
    ],
    "season_tags": [
      "عام"
    ]
  }
]