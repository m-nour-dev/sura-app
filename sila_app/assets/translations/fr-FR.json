  "sunnah_explanation_button": "Expliquer",
  "close_button": "Fermer",
  "sunnah_1_text": "Se rincer la bouche et le nez avec une seule poignée d'eau",
  "sunnah_1_source": "Approuvé",
  "sunnah_1_explanation": "Prendre une seule poignée d'eau pour se rincer la bouche et le nez, et ce trois fois.",
  "sunnah_2_text": "L'invocation après les ablutions",
  "sunnah_2_source": "Tirmidhi",
  "sunnah_2_explanation": "Dire : 'J'atteste qu'il n'y a de divinité digne d'adoration qu'Allah...'",
  "sunnah_3_text": "Deux unités de prière après les ablutions",
  "sunnah_3_source": "Approuvé",
  "sunnah_3_explanation": "Prier deux raka'ats après l'ablution apporte le pardon d'Allah.",
  "sunnah_4_text": "L'invocation d'ouverture de la prière",
  "sunnah_4_source": "Boukhari et Mouslim",
  "sunnah_4_explanation": "Varier les invocations d'ouverture de la prière comme l'a fait le Prophète.",
  "sunnah_5_text": "Le Siwak avant chaque prière",
  "sunnah_5_source": "Approuvé",
  "sunnah_5_explanation": "Le Siwak purifie la bouche et apporte la satisfaction du Seigneur.",
  "sunnah_6_text": "Prier vers un obstacle (Soutra)",
  "sunnah_6_source": "Approuvé",
  "sunnah_6_explanation": "Se mettre face à un obstacle lors de la prière.",
  "sunnah_7_text": "S'asseoir momentanément",
  "sunnah_7_source": "Boukhari",
  "sunnah_7_explanation": "S'asseoir un court instant avant de se relever pour la deuxième ou quatrième rak'ah.",
  "sunnah_8_text": "La position d'Al-Iq'aa",
  "sunnah_8_source": "Mouslim",
  "sunnah_8_explanation": "Rester sur ses talons entre deux prosternations.",
  "sunnah_9_text": "Se prosterner de reconnaissance",
  "sunnah_9_source": "Aboû Dâwoûd et Tirmidhi",
  "sunnah_9_explanation": "Faire une prosternation lorsqu'un bienfait survient.",
  "sunnah_10_text": "Secouer le lit avant de dormir",
  "sunnah_10_source": "Approuvé",
  "sunnah_10_explanation": "Secouer le lit pour enlever ce qui a pu s'y loger.",
  "sunnah_11_text": "Dormir en état de pureté",
  "sunnah_11_source": "Approuvé",
  "sunnah_11_explanation": "Faire ses ablutions avant de se coucher.",
  "sunnah_12_text": "Lire la sourate Al-Moulk la nuit",
  "sunnah_12_source": "Tirmidhi",
  "sunnah_12_explanation": "Protège du châtiment de la tombe.",
  "sunnah_13_text": "Lécher ses doigts après manger",
  "sunnah_13_source": "Mouslim",
  "sunnah_13_explanation": "Pour obtenir la bénédiction (Baraka) dans son repas.",
  "sunnah_14_text": "Louer Allah après manger",
  "sunnah_14_source": "Mouslim",
  "sunnah_14_explanation": "Dire 'Louange à Allah qui nous a nourris...'",
  "sunnah_15_text": "Respirer en dehors du récipient",
  "sunnah_15_source": "Approuvé",
  "sunnah_15_explanation": "Boire en trois gorgées et respirer en dehors du récipient.",
  "sunnah_16_text": "Être le premier à saluer",
  "sunnah_16_source": "Aboû Dâwoûd",
  "sunnah_16_explanation": "Initier le Salam.",
  "sunnah_17_text": "Diffuser le Salam",
  "sunnah_17_source": "Approuvé",
  "sunnah_17_explanation": "Saluer ceux que l'on connaît et ceux que l'on ne connaît pas.",
  "sunnah_18_text": "Sourire à son frère",
  "sunnah_18_source": "Tirmidhi",
  "sunnah_18_explanation": "Sourire est une aumône.",
  "sunnah_19_text": "Se serrer la main",
  "sunnah_19_source": "Tirmidhi",
  "sunnah_19_explanation": "Permet aux péchés de tomber des mains.",
  "sunnah_20_text": "Visiter les tombes",
  "sunnah_20_source": "Mouslim",
  "sunnah_20_explanation": "Rappelle de l'au-delà.",
  "sunnah_21_text": "Prière de la matinée (Duha)",
  "sunnah_21_source": "Mouslim",
  "sunnah_21_explanation": "Deux raka'ats pour être reconnaissant.",
  "sunnah_22_text": "Prière impaire (Witr)",
  "sunnah_22_source": "Approuvé",
  "sunnah_22_explanation": "Terminer sa prière nocturne par une prière de Witr.",
  "sunnah_23_text": "Marcher nu-pieds occasionnellement",
  "sunnah_23_source": "Aboû Dâwoûd",
  "sunnah_23_explanation": "Par humilité pour le Seigneur.",
  "sunnah_24_text": "Rédiger son testament",
  "sunnah_24_source": "Approuvé",
  "sunnah_24_explanation": "Ne pas dormir deux nuits sans inscrire son testament.",
  "sunnah_25_text": "Invocations pendant la pluie",
  "sunnah_25_source": "Boukhari",
  "sunnah_25_explanation": "Demander une pluie bénéfique.",
  "sunnah_26_text": "Garder les enfants au coucher du soleil",
  "sunnah_26_source": "Approuvé",
  "sunnah_26_explanation": "Pour éviter le mal des diables au coucher du soleil.",
